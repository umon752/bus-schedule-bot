# 環境變數設定說明
# 複製此檔案為 .env，並填入你的實際金鑰

# ────────────────────────────────────────
# TDX 交通資料流通服務平台
# 申請網址：https://tdx.transportdata.tw/register
# 登入後前往「會員中心 > 金鑰管理」取得
# ────────────────────────────────────────
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=

# ────────────────────────────────────────
# LINE Messaging API
# 建立步驟：
# 1. 前往 https://developers.line.biz/
# 2. 建立 Provider → 新增 Messaging API Channel
# 3. Messaging API 頁籤 → Issue Channel access token
# 4. 你的 LINE User ID 在 Messaging API 頁籤最下方
# ────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# ────────────────────────────────────────
# 公車站牌設定（與 TDX 資料庫站名一致）
# ────────────────────────────────────────
BUS_FROM_STOP=新坡
BUS_TO_STOP=天祥醫院

# 所在縣市（桃園市=Taoyuan, 新北市=NewTaipei, 台北市=Taipei, 基隆市=Keelung...）
# 若為公路客運（跨縣市）請留空
BUS_CITY=Taoyuan

# 若為公路客運子業者代碼，例如：KLBus, TaiwanTripBus...（TDX 公路客運 Operator 代碼）
BUS_OPERATOR=

# 排程時區
TIMEZONE=Asia/Taipei
